<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_wc_shipping_carrier_list" model="ir.ui.view">
        <field name="name">wc.shipping.carrier.list</field>
        <field name="model">wc.shipping.carrier</field>
        <field name="arch" type="xml">
            <list string="WooCommerce Shipping Methods" create="0" delete="0" edit="0">
                <field name="name"/>
                <field name="wc_method_id"/>
                <field name="carrier_id"/>
                <field name="external_id"/>
                <field name="backend_id"/>
                <field name="sync_date"/>
            </list>
        </field>
    </record>

    <record id="view_wc_shipping_carrier_form" model="ir.ui.view">
        <field name="name">wc.shipping.carrier.form</field>
        <field name="model">wc.shipping.carrier</field>
        <field name="arch" type="xml">
            <form string="WooCommerce Shipping Method" create="0" delete="0" edit="0">
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="carrier_id" readonly="1"/>
                            <field name="wc_method_id" readonly="1"/>
                            <field name="wc_instance_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="external_id" readonly="1"/>
                            <field name="backend_id" readonly="1"/>
                            <field name="sync_date" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_wc_shipping_carrier" model="ir.actions.act_window">
        <field name="name">WooCommerce Shipping Methods</field>
        <field name="res_model">wc.shipping.carrier</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
