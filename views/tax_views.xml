<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_wc_tax_link_list" model="ir.ui.view">
        <field name="name">wc.tax.link.list</field>
        <field name="model">wc.tax.link</field>
        <field name="arch" type="xml">
            <list string="WooCommerce Tax Rates">
                <field name="name"/>
                <field name="wc_rate"/>
                <field name="wc_tax_class"/>
                <field name="wc_compound"/>
                <field name="external_id"/>
                <field name="backend_id"/>
                <field name="sync_date"/>
            </list>
        </field>
    </record>

    <record id="view_wc_tax_link_form" model="ir.ui.view">
        <field name="name">wc.tax.link.form</field>
        <field name="model">wc.tax.link</field>
        <field name="arch" type="xml">
            <form string="WooCommerce Tax Rate">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="tax_id"/>
                            <field name="wc_rate"/>
                            <field name="wc_tax_class"/>
                        </group>
                        <group>
                            <field name="external_id" readonly="1"/>
                            <field name="backend_id"/>
                            <field name="wc_compound"/>
                            <field name="wc_shipping"/>
                            <field name="sync_date"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_wc_tax_link" model="ir.actions.act_window">
        <field name="name">WooCommerce Tax Rates</field>
        <field name="res_model">wc.tax.link</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
