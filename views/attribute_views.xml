<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_wc_attribute_link_list" model="ir.ui.view">
        <field name="name">wc.attribute.link.list</field>
        <field name="model">wc.attribute.link</field>
        <field name="arch" type="xml">
            <list string="WooCommerce Attributes">
                <field name="name"/>
                <field name="wc_slug"/>
                <field name="wc_type"/>
                <field name="external_id"/>
                <field name="backend_id"/>
                <field name="sync_date"/>
            </list>
        </field>
    </record>

    <record id="view_wc_attribute_link_form" model="ir.ui.view">
        <field name="name">wc.attribute.link.form</field>
        <field name="model">wc.attribute.link</field>
        <field name="arch" type="xml">
            <form string="WooCommerce Attribute">
                <header>
                    <button name="push_to_store" string="Push to WooCommerce" type="object" class="btn-primary"/>
                    <button name="pull_from_store" string="Pull from WooCommerce" type="object" invisible="not external_id"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="attribute_id"/>
                            <field name="wc_slug"/>
                            <field name="wc_type"/>
                        </group>
                        <group>
                            <field name="external_id" readonly="1"/>
                            <field name="backend_id"/>
                            <field name="wc_order_by"/>
                            <field name="wc_has_archives"/>
                            <field name="sync_date"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_wc_attribute_link" model="ir.actions.act_window">
        <field name="name">WooCommerce Attributes</field>
        <field name="res_model">wc.attribute.link</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_push_wc_attribute_to_store_server" model="ir.actions.server">
        <field name="name">Push to WooCommerce</field>
        <field name="model_id" ref="ad_woocomerce_connector.model_wc_attribute_link"/>
        <field name="binding_model_id" ref="ad_woocomerce_connector.model_wc_attribute_link"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            if records:
                action = records.push_to_store()
        </field>
    </record>

    <record id="action_pull_wc_attribute_from_store_server" model="ir.actions.server">
        <field name="name">Pull from WooCommerce</field>
        <field name="model_id" ref="ad_woocomerce_connector.model_wc_attribute_link"/>
        <field name="binding_model_id" ref="ad_woocomerce_connector.model_wc_attribute_link"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            if records:
                action = records.pull_from_store()
        </field>
    </record>

</odoo>
