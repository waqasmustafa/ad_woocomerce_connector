<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_wc_payment_mode_list" model="ir.ui.view">
        <field name="name">wc.payment.mode.list</field>
        <field name="model">wc.payment.mode</field>
        <field name="arch" type="xml">
            <list string="WooCommerce Payment Methods" create="0" delete="0">
                <field name="name"/>
                <field name="external_id"/>
                <field name="is_enabled"/>
                <field name="journal_id"/>
                <field name="backend_id"/>
            </list>
        </field>
    </record>

    <record id="view_wc_payment_mode_form" model="ir.ui.view">
        <field name="name">wc.payment.mode.form</field>
        <field name="model">wc.payment.mode</field>
        <field name="arch" type="xml">
            <form string="WooCommerce Payment Method" create="0" delete="0">
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="external_id" readonly="1"/>
                            <field name="is_enabled" readonly="1"/>
                        </group>
                        <group>
                            <field name="backend_id" readonly="1"/>
                            <field name="journal_id"/>
                            <field name="description" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_wc_payment_mode" model="ir.actions.act_window">
        <field name="name">WooCommerce Payment Methods</field>
        <field name="res_model">wc.payment.mode</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
