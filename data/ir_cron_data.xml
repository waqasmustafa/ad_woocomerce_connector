<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="cron_wc_pull_metadata" model="ir.cron">
        <field name="name">WooCommerce: Refresh Store Metadata</field>
        <field name="model_id" ref="model_wc_store"/>
        <field name="state">code</field>
        <field name="code">model.cron_pull_metadata()</field>
        <field name="interval_number">7</field>
        <field name="interval_type">days</field>
        <field name="active" eval="False"/>
    </record>

